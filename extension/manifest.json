{
  "manifest_version": 2,
  "name": "Snack Interceptor",
  "version": "1.0",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "tabs",
    "scripting",
    "alarms",
    "*://exp.host/*",
    "*://snack.expo.dev/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://snack.expo.dev/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Snack Interceptor"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "snack-interceptor@sua-extensao.com",
      "strict_min_version": "57.0"
    }
  }
}