{
  "manifest_version": 3,
  "name": "Snack Interceptor",
  "version": "1.0",
  "permissions": [
    "webRequest",
    "declarativeNetRequest",
    "tabs",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "*://exp.host/*",
    "*://snack.expo.dev/*",
    "http://localhost:*/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://snack.expo.dev/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Snack Interceptor"
  }
}