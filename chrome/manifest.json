{
  "manifest_version": 2,
  "name": "Snack Interceptor",
  "version": "1.0",
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "tabs",
    "scripting",
    "*://exp.host/*",
    "*://snack.expo.dev/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  }
}